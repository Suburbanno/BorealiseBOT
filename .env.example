# ── Borealise Chatbot — environment variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.

# ── Bot credentials ───────────────────────────────────────────────────────────
# Borealise account the bot will log in as
BOT_EMAIL=bot@example.com
BOT_PASSWORD=yourpassword

# Slug of the room the bot should join (e.g. "lounge", "main")
BOT_ROOM=room-slug

# ── Platform endpoints ────────────────────────────────────────────────────────
# REST API base URL (no trailing slash)
BOREALISE_API_URL=https://prod.borealise.com/api

# WebSocket pipeline URL
BOREALISE_WS_URL=wss://prod.borealise.com/ws

# ── Bot behaviour ─────────────────────────────────────────────────────────────
# Prefix for chat commands (default: !)
CMD_PREFIX=!

# Auto-woot every track? (true / false)
AUTO_WOOT=true

# Auto-join the waitlist? (true / false)
AUTO_JOIN=false

# Reply when mentioned while "AFK" — leave blank to disable
AFK_MESSAGE=

# ── Optional ──────────────────────────────────────────────────────────────────
# Minimum milliseconds between AFK replies to the same user (default 30 000)
# AFK_COOLDOWN_MS=30000
